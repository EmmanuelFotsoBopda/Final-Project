import json


def load_tasks(DATA_FILE)-> list[dict]:
    """
    Read the JSON Lines file and return a list of task dictionaries.
    If the file does not exist, return an empty list.
    Each non-empty line is stripped and parsed with json.loads.
    Invalid JSON lines are skipped (logged to stdout).
    """
    if not DATA_FILE.exists():
        return []

    tasks: list[dict] = []
    with DATA_FILE.open("r", encoding="utf-8") as f:
        for lineno, line in enumerate(f, start=1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
                tasks.append(obj)
            except json.JSONDecodeError:
                # Skip invalid lines but print a warning. You can change this to raise if you prefer.
                print(f"Warning: skipping invalid JSON on line {lineno} in {DATA_FILE}")
                continue
    return tasks
      
    
def save_tasks(DATA_FILE, tasks: list[dict]) -> None:
    """
    Overwrite the data file with the given tasks list in JSON Lines format.
    Each task is converted with json.dumps and written as a single line.
    """
    # Ensure parent directory exists (optional)
    DATA_FILE.parent.mkdir(parents=True, exist_ok=True)
    with DATA_FILE.open("w", encoding="utf-8") as f:
        for task in tasks:
            # Ensure stable JSON output; ensure_ascii=False keeps Unicode readable
            f.write(json.dumps(task, ensure_ascii=False) + "\n")
            
# Helper to find task index by id
def _find_task_index(_tasks, task_id: int) -> [int]:
    for idx, t in enumerate(_tasks):
        try:
            if int(t.get("id")) == task_id:
                return idx
        except Exception:
            continue
    return None
